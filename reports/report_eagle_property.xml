<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <template id="property_details_sub">
        <div class="property-box" style="border: 1px solid black; padding: 10px; margin-bottom: 10px;">
            <strong>Property Name:</strong>
            <span t-out="doc.name" />
            <br />
            <strong>Construction:</strong>
            <span t-out="doc.construction_date" />
            <br />

            <div class="custom-content" style="color: blue;">
                <t t-out="0" />
            </div>
        </div>
    </template>

    <template id="report_eagle_property">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="newt" t-value="doc.parent_id.name" />

                <t t-call="eagle_estates.property_details_sub">
                    <span>Parent Building: <t t-out="newt" /></span>

                    <t t-if="newt == 'Burj Khalifa'">
                        <p style="color: green;">
                            <strong>Special Status: YES</strong>
                        </p>
                    </t>
                    <t t-else="">
                        <p>Special Status: No</p>
                    </t>
                </t>

                <t t-foreach="doc.tag_ids" t-as="tag">
                    <div>
                        <span t-out="tag_index" />
                        <span t-out="tag.name" />
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_eagle_property" model="ir.actions.report">
        <field name="name">Eagle Property Report</field>
        <field name="model">eagle.property</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">eagle_estates.report_eagle_property</field>
        <field name="print_report_name">'Newton - ' + object.name</field>
        <field name="binding_type">report</field>
        <field name="binding_model_id" ref="model_eagle_property" />
        <field name="paperformat_id" ref="base.paperformat_euro" />
    </record>
</odoo>
